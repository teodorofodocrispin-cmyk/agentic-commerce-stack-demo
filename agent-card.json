{
  "schema_version": "v1",
  "name": "Agentic Commerce Stack Demo Agent",
  "description": "Reference autonomous agent that pays and chains the LATAM Agentic Commerce Stack (TrustBoost -> Intelica -> VeraData) via x402. Proves the end-to-end M2M loop works.",
  "version": "1.0.0",
  "category": "reference-agent",

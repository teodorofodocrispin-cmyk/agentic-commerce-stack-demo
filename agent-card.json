  "depends_on": {
    "trustboost": {
      "name": "TrustBoost PII Sanitizer",
      "agent_card": "https://api.trustboost.dev/.well-known/agent-card.json",
      "pricing": "https://api.trustboost.dev/pricing",
      "role": "PII sanitization BEFORE any text reaches an LLM"
    },
    "intelica": {
      "name": "Intelica Competitive Intelligence",
      "agent_card": "https://api.intelica.dev/.well-known/agent-card.json",
      "pricing": "https://api.intelica.dev/pricing",
      "role": "competitive/market intelligence BEFORE strategic decisions"
    },
    "veradata": {
      "name": "VeraData Verified LATAM Data",
      "agent_card": "https://api.veradata.dev/.well-known/agent-card.json",
